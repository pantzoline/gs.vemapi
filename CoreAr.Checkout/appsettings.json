{
  // ============================================================
  // CORE-AR — appsettings.json (TEMPLATE DE DESENVOLVIMENTO)
  // ⚠️ NUNCA commite valores reais de produção neste arquivo.
  //    Use AWS Secrets Manager, Azure Key Vault ou .env para prod.
  // ============================================================

  "Auth": {
    // URL do seu tenant no Auth0 (ex: https://SEU-DOMINIO.auth0.com/)
    // ou URL do Keycloak (ex: http://localhost:8080/realms/corear)
    "Authority": "https://SEU-DOMINIO.auth0.com/",
    "Audience":  "https://api.corear.com.br"
  },

  "ConnectionStrings": {
    // Postgres: altere usuário/senha conforme docker-compose.yml
    "Postgres": "Host=localhost;Port=5432;Database=corear;Username=corear_admin;Password=CHANGE_ME_IN_PRODUCTION",
    // Redis: deve incluir a senha configurada no docker-compose.yml
    "Redis":    "localhost:6379,password=CHANGE_ME_IN_PRODUCTION"
  },

  "RabbitMQ": {
    "Host":     "localhost",
    "Port":     5672,
    "Username": "corear_admin",
    "Password": "CHANGE_ME_IN_PRODUCTION",
    // Filas (não altere os nomes sem atualizar o código dos consumers)
    "Filas": {
      "EmitirNotas":       "billing.emitir-notas",
      "EmitirNotasDlq":    "billing.emitir-notas.dlq",
      "Notificacoes":      "crm.notificacoes-renovacao"
    }
  },

  "FocusNfe": {
    // Obtenha em https://focusnfe.com.br
    "BaseUrl": "https://homologacao.focusnfe.com.br/v2/",
    "ApiKey":  "COLE_SUA_API_KEY_AQUI"
  },

  "ZAPI": {
    // Obtenha em https://z-api.io
    // BaseUrl: https://api.z-api.io/instances/SUA_INSTANCIA/token/SEU_TOKEN
    "BaseUrl":     "https://api.z-api.io/instances/SUA_INSTANCIA/token/SEU_TOKEN/",
    "ClientToken": "COLE_SEU_CLIENT_TOKEN_AQUI"
  },

  "SendGrid": {
    // Obtenha em https://sendgrid.com
    "ApiKey": "SG.COLE_SUA_API_KEY_AQUI"
  },

  // ============================================================
  // CHAVES DE WEBHOOK POR TENANT
  // Cada AR tem sua própria chave secreta para validação HMAC.
  // Em produção, mova para AWS Secrets Manager ou Vault.
  // Formato: "ID-DO-TENANT": "CHAVE-SECRETA-DO-GATEWAY"
  // ============================================================
  "Gateways": {
    "WebhookSecret": {
      "00000000-0000-0000-0000-000000000001": "chave-secreta-ar-exemplo"
    }
  },

  "Logging": {
    "LogLevel": {
      "Default":                   "Information",
      "Microsoft.AspNetCore":      "Warning",
      "Microsoft.EntityFramework": "Warning"
    }
  },

  "AllowedHosts": "*"
}
