{
  // Sobrescreve appsettings.json para ambiente de desenvolvimento
  // Este arquivo é carregado automaticamente quando ASPNETCORE_ENVIRONMENT=Development

  "Auth": {
    // Em dev, pode desabilitar validação estrita se quiser testar sem Auth0/Keycloak
    "Authority": "https://SEU-DOMINIO.auth0.com/",
    "Audience":  "https://api.corear.com.br"
  },

  "Logging": {
    "LogLevel": {
      "Default":                   "Debug",
      "Microsoft.AspNetCore":      "Information",
      "Microsoft.EntityFramework": "Information",
      "CoreAr":                    "Debug"
    }
  }
}
